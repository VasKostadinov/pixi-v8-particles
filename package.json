{
  "name": "pixi-v8-particles",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Vendored pixijs particle-emitter ported for pixi.js v8, plus a standalone visual editor.",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./editor-config": "./src/behaviors/editor/index.ts"
  },
  "scripts": {
    "dev": "vite --config editor/vite.config.ts",
    "build": "tsc -p editor/tsconfig.json && vite build --config editor/vite.config.ts",
    "preview": "vite preview --config editor/vite.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "pixi.js": "^8.8.1",
    "prettier": "3.8.3",
    "typescript": "~5.7.3",
    "vite": "^6.2.0"
  }
}
