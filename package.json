{
  "name": "pixi-v8-particles",
  "version": "0.1.2",
  "type": "module",
  "description": "Vendored pixijs particle-emitter ported for pixi.js v8, plus a standalone visual editor.",
  "license": "MIT",
  "author": "VasKostadinov",
  "homepage": "https://github.com/VasKostadinov/pixi-v8-particles#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VasKostadinov/pixi-v8-particles.git"
  },
  "bugs": {
    "url": "https://github.com/VasKostadinov/pixi-v8-particles/issues"
  },
  "keywords": [
    "pixi",
    "pixi.js",
    "pixi-v8",
    "particles",
    "particle-emitter",
    "particle-system",
    "vfx",
    "webgl",
    "webgpu"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite --config editor/vite.config.ts",
    "build": "tsc -p tsconfig.build.json",
    "build:editor": "tsc -p editor/tsconfig.json && vite build --config editor/vite.config.ts",
    "prepublishOnly": "npm run build",
    "preview": "vite preview --config editor/vite.config.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "release": "npm version minor -m \"chore: release v%s\" && npm publish && git push --follow-tags"
  },
  "peerDependencies": {
    "pixi.js": "^8.0.0"
  },
  "devDependencies": {
    "json5": "^2.2.3",
    "pixi.js": "^8.8.1",
    "prettier": "3.8.3",
    "typescript": "~5.7.3",
    "vite": "^6.2.0"
  }
}
